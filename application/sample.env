# Copy this file to ../.env (project root) and fill in the values.
# Do NOT commit .env — it is gitignored.

# ── LLM ─────────────────────────────────────────────────
# Required. Used for Claude chat responses and source verification.
CLAUDE_API_KEY=sk-...

# Optional. If omitted, the app uses Claude Sonnet 4.6 by default.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional. If omitted, uses the same default as CLAUDE_MODEL.
SOURCES_VERIFIER_MODEL=claude-sonnet-4-6

# ── AWS credentials ──────────────────────────────────────
# Required for Bedrock Knowledge Base (RAG).
# Option A: explicit keys
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# Option B: named profile (omit the keys above and set this instead)
# AWS_PROFILE=your-profile

# ── Bedrock Knowledge Base (RAG) ─────────────────────────
# Required. KB lives in us-west-2 for both dev and prod.
AWS_KB_ID=Z2NHZ8JMMQ
AWS_REGION=us-west-2

# ── Message logging (PostgreSQL) ─────────────────────────
# Optional. If omitted, chat still works but messages are not persisted.
# Use DATABASE_URL or the individual DB_* vars — not both.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_PORT=5432

# ── Transcript download (S3) ─────────────────────────────
# Optional. If omitted, transcript download is disabled.
# TRANSCRIPT_BUCKET_NAME=

# ── Session / Admin Auth ─────────────────────────────────
# Optional. If omitted, a random key is generated each restart (sessions won't survive restarts).
# SESSION_SECRET=

# ── Docker Hub (for docker_build.sh) ─────────────────────
# Optional. Only needed if pushing to Docker Hub.
# DOCKER_HUB_USERNAME=
